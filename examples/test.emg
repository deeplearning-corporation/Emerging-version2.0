-- Emerging 2.0 测试程序
using "iostream"

func main() -> int
{
    out("Hello, Emerging 2.0!")
    
    -- 文件操作
    create("test.txt")
    textfile("Hello from Emerging 2.0")
    
    -- 系统命令
    syscmd("dir")
    
    -- 磁盘操作
    disk.read(0, buffer, 512)
    disk.write(0, buffer, 512)
    
    -- 硬件操作
    hardware.port_out(0x3F8, 'A')
    hardware.interrupt(0x13)
    
    -- 内存操作
    using "memory"
    memory.copy(dest, src, 1024)
    
    ret
}